      "types": "./src/fixtures/index.ts",
      "import": "./src/fixtures/index.ts"
    }
  },
  "dependencies": {
    "@repo/domain": "workspace:*",
    "@repo/ui": "workspace:*",
    "lucide-react": "^1.14.0",
    "motion": "^12.38.0",
    "recharts": "^3.8.1",
    "ts-pattern": "^5.9.0"
  },
  "devDependencies": {
    "@repo/test-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.5",
    "axe-core": "^4.11.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "vitest": "^4.1.5",
    "vitest-axe": "^0.1.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "scripts": {
